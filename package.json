{
  "name": "listamigo",
  "version": "1.0.0",
  "description": "Listamigo",
  "scripts": {
    "build": "npx tsc --noEmit && npx esbuild src/main.ts --bundle --outfile=dist/app.js --format=iife --minify --drop:debugger --metafile=dist/meta.json",
    "analyze": "npx esbuild-visualizer --metadata dist/meta.json --open",
    "watch": "npx esbuild src/main.ts --bundle --outfile=dist/app.js --format=esm --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "npx tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "esbuild": "^0.28.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "ably": "^2.21.0"
  }
}
